# MASTER_CONTROL environment configuration
# Copy to .env and fill in your API keys

# Anthropic (Claude)
MASTERCTL_ANTHROPIC_API_KEY=
MASTERCTL_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI
MASTERCTL_OPENAI_API_KEY=
MASTERCTL_OPENAI_MODEL=gpt-4o

# DeepInfra (OpenAI-compatible endpoint)
MASTERCTL_DEEPINFRA_API_KEY=
MASTERCTL_DEEPINFRA_MODEL=Qwen/Qwen3-14B

# Projects directory (parent of all managed projects)
MASTERCTL_PROJECTS_DIR=/path/to/your/projects

# Server
MASTERCTL_HOST=127.0.0.1
MASTERCTL_PORT=8000
